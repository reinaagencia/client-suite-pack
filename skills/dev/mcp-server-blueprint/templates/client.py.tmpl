"""
Cliente HTTP async para consumo de APIs externas desde las tools MCP.

Provee:
- Timeout configurable (default: 30s)
- Retry automático para errores transitorios (5xx, timeout)
- Manejo estructurado de errores (APIError con status_code + details)
- Logging de cada request/response

Uso:
    client = APIClient(base_url="https://api.example.com", api_key="...")
    data = await client.get("/users/123")
    result = await client.post("/orders", json={...})
"""

from __future__ import annotations

import logging
from typing import Any

import httpx

logger = logging.getLogger(__name__)


class APIError(Exception):
    """Error estructurado de API.

    Attributes:
        status_code: Código HTTP del error.
        message: Mensaje descriptivo.
        details: Cuerpo de la respuesta de error (si aplica).
    """

    def __init__(
        self,
        status_code: int,
        message: str = "",
        details: dict | None = None,
    ) -> None:
        self.status_code = status_code
        self.details = details or {}
        super().__init__(message or f"HTTP {status_code}")

    def __str__(self) -> str:
        base = f"APIError(status={self.status_code})"
        if self.details:
            return f"{base}: {self.details}"
        return base


class APIClient:
    """Cliente HTTP async con timeout, retry, y manejo de errores.

    Args:
        base_url: URL base de la API (ej: "https://api.example.com/v1").
        api_key: Token de autenticación (opcional).
        timeout: Timeout en segundos para cada request (default: 30.0).
        max_retries: Número máximo de reintentos para errores transitorios (default: 2).
    """

    def __init__(
        self,
        base_url: str,
        api_key: str = "",
        timeout: float = 30.0,
        max_retries: int = 2,
    ) -> None:
        self.base_url = base_url.rstrip("/")
        self.api_key = api_key
        self.timeout = timeout
        self.max_retries = max_retries

        headers: dict[str, str] = {
            "Content-Type": "application/json",
            "Accept": "application/json",
            "User-Agent": "MCP-Server-Client/1.0",
        }
        if api_key:
            headers["Authorization"] = f"Bearer {api_key}"

        self._client = httpx.AsyncClient(
            base_url=self.base_url,
            headers=headers,
            timeout=httpx.Timeout(timeout),
            follow_redirects=True,
        )

    async def get(
        self,
        path: str,
        params: dict[str, Any] | None = None,
    ) -> dict:
        """Ejecuta una petición GET.

        Args:
            path: Ruta relativa (ej: "/users/123").
            params: Query parameters opcionales.

        Returns:
            Dict con la respuesta JSON.

        Raises:
            APIError: Si la API retorna un error HTTP.
        """
        return await self._request("GET", path, params=params)

    async def post(
        self,
        path: str,
        json: dict | None = None,
    ) -> dict:
        """Ejecuta una petición POST.

        Args:
            path: Ruta relativa (ej: "/orders").
            json: Cuerpo de la petición como dict.

        Returns:
            Dict con la respuesta JSON.

        Raises:
            APIError: Si la API retorna un error HTTP.
        """
        return await self._request("POST", path, json=json)

    async def put(
        self,
        path: str,
        json: dict | None = None,
    ) -> dict:
        """Ejecuta una petición PUT.

        Args:
            path: Ruta relativa (ej: "/users/123").
            json: Cuerpo de la petición como dict.

        Returns:
            Dict con la respuesta JSON.
        """
        return await self._request("PUT", path, json=json)

    async def delete(
        self,
        path: str,
    ) -> dict:
        """Ejecuta una petición DELETE.

        Args:
            path: Ruta relativa (ej: "/users/123").

        Returns:
            Dict con la respuesta JSON.
        """
        return await self._request("DELETE", path)

    async def _request(
        self,
        method: str,
        path: str,
        params: dict[str, Any] | None = None,
        json: dict | None = None,
    ) -> dict:
        """Ejecuta un request HTTP con retry y manejo de errores.

        Args:
            method: HTTP method (GET, POST, PUT, DELETE).
            path: Ruta relativa.
            params: Query parameters.
            json: Cuerpo JSON.

        Returns:
            Dict con respuesta parseada.
        """
        url = f"{self.base_url}{path}"
        last_error: Exception | None = None

        for attempt in range(1, self.max_retries + 2):  # +1 para el intento inicial
            try:
                logger.debug(f"[{attempt}] {method} {url}")

                response = await self._client.request(
                    method=method,
                    url=path,
                    params=params,
                    json=json,
                )

                # Logging de respuesta
                logger.debug(f"[{attempt}] {method} {url} → {response.status_code}")

                # Manejo de errores HTTP
                if response.is_success:
                    if response.content:
                        return response.json()
                    return {"status": "ok"}

                # Errores del lado del servidor (retryables)
                if response.status_code >= 500 and attempt <= self.max_retries:
                    logger.warning(
                        f"Retry {attempt}/{self.max_retries} for {url} "
                        f"(HTTP {response.status_code})"
                    )
                    continue

                # Errores del cliente (no retry)
                try:
                    details = response.json()
                except Exception:
                    details = {"body": response.text[:500]}

                raise APIError(
                    status_code=response.status_code,
                    message=f"HTTP {response.status_code} for {method} {path}",
                    details=details,
                )

            except httpx.TimeoutException as exc:
                last_error = exc
                if attempt <= self.max_retries:
                    logger.warning(
                        f"Retry {attempt}/{self.max_retries} for {url} "
                        f"(timeout after {self.timeout}s)"
                    )
                    continue
                raise APIError(
                    status_code=0,
                    message=f"Request timed out after {self.timeout}s: {method} {path}",
                ) from exc

            except httpx.RequestError as exc:
                last_error = exc
                if attempt <= self.max_retries:
                    logger.warning(
                        f"Retry {attempt}/{self.max_retries} for {url} "
                        f"(connection error: {exc})"
                    )
                    continue
                raise APIError(
                    status_code=0,
                    message=f"Connection error: {exc}",
                ) from exc

        # Si llegamos aquí, todos los retries fallaron
        raise APIError(
            status_code=0,
            message=f"All {self.max_retries + 1} attempts failed for {method} {path}",
        ) from last_error

    async def close(self) -> None:
        """Cierra el cliente HTTP y libera recursos."""
        await self._client.aclose()

    # Context manager para uso con async with
    async def __aenter__(self) -> APIClient:
        return self

    async def __aexit__(self, *args: Any) -> None:
        await self.close()
